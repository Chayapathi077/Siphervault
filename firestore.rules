rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        incoming().uid == userId;
      allow update: if isOwner(userId) && 
        incoming().uid == existing().uid;
      allow delete: if isOwner(userId);
    }

    // File Rules
    match /files/{fileId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && (resource.data.ownerId == request.auth.uid || resource.data.isShared == true);
      allow create: if isSignedIn() && 
        incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && 
        existing().ownerId == request.auth.uid &&
        incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && 
        existing().ownerId == request.auth.uid;
    }

    // Folder Rules
    match /folders/{folderId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && 
        incoming().ownerId == request.auth.uid;
      allow update: if isSignedIn() && 
        existing().ownerId == request.auth.uid &&
        incoming().ownerId == existing().ownerId;
      allow delete: if isSignedIn() && 
        existing().ownerId == request.auth.uid;
    }
  }
}
